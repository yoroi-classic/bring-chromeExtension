{
  "name": "@emurgo/bringweb3-chrome-extension-kit",
  "version": "1.5.1-fix.3",
  "description": "Crypto cashback integration kit for crypto outlets extension",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "license": "MIT",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yoroi-classic/bring-chromeExtension"
  },
  "scripts": {
    "watch": "tsup index.ts --env.IFRAME_URL=http://localhost:5173 --env.ENDPOINT=dev --env.VERSION=1.5.0 --format cjs,esm --dts --watch",
    "prebuild": "node scripts/ensure-dist.js",
    "build": "tsup index.ts --format cjs,esm --dts --minify",
    "build:dev": "tsup index.ts --format cjs,esm --dts --minify --env.ENDPOINT=dev --env.VERSION=1.5.0",
    "lint": "tsc",
    "test": "vitest run --coverage",
    "test:smoke": "yarn build && node scripts/run-smoke.js",
    "release": "yarn build && changeset publish"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "devDependencies": {
    "@changesets/cli": "^2.27.7",
    "@types/chrome": "^0.0.268",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.0.5",
    "tsup": "^8.2.1",
    "typescript": "^5.5.3",
    "vitest": "^2.0.5"
  },
  "keywords": [
    "cashback",
    "crypto",
    "bringweb3"
  ],
  "dependencies": {
    "uuid": "^11.0.3"
  }
}
